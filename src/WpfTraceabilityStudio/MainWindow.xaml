<Window x:Class="WpfTraceabilityStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:WpfTraceabilityStudio.ViewModels"
        mc:Ignorable="d"
        Title="WPF Traceability Studio"
        Width="1480"
        Height="960"
        Background="#F3F6FC"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                Background="#0F1F4A"
                CornerRadius="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="14"
                               Foreground="#8EC5FF"
                               Text="WPF / MVVM Demo" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="物料-影像关联分析台" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="15"
                               Foreground="#CEDAF7"
                               TextWrapping="Wrap"
                               Text="围绕序列号回溯、站点履历、AOI 影像复判和工程结论形成一个完整的上位机/工程工具演示，强调 MVVM 数据绑定与可维护结构。" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="18"
                        Background="#192E68"
                        CornerRadius="22">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   Foreground="#9CC4FF"
                                   Text="当前状态" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding StatusHeadline}" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#D5E3FF"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusDetail}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="520" />
            </Grid.ColumnDefinitions>

            <UniformGrid Rows="1" Columns="4" Margin="0,0,18,0">
                <Border Margin="0,0,14,0" Padding="16" Background="White" CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="#627699" Text="Serial" />
                        <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="Bold" Text="{Binding SelectedSerialNumber}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,14,0" Padding="16" Background="White" CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="#627699" Text="Lot" />
                        <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="Bold" Text="{Binding SelectedLotNumber}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,14,0" Padding="16" Background="White" CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="#627699" Text="Current Station" />
                        <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="Bold" Text="{Binding SelectedCurrentStation}" />
                    </StackPanel>
                </Border>
                <Border Padding="16" Background="White" CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="#627699" Text="Grade" />
                        <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="Bold" Text="{Binding SelectedGrade}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Column="1" Padding="18" Background="White" CornerRadius="22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="#627699" Text="查找回溯对象" />
                        <TextBox Margin="0,10,0,0"
                                 Padding="12"
                                 FontSize="15"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                            <Button Padding="18,10"
                                    Margin="0,0,10,0"
                                    Command="{Binding SearchCommand}"
                                    Content="搜索" />
                            <Button Padding="18,10"
                                    Margin="0,0,10,0"
                                    Command="{Binding LoadSampleCommand}"
                                    CommandParameter="PKG-240426-00017"
                                    Content="异常样本" />
                            <Button Padding="18,10"
                                    Command="{Binding LoadSampleCommand}"
                                    CommandParameter="PKG-240426-00011"
                                    Content="正常样本" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Margin="18,0,0,0"
                            Padding="18,10"
                            VerticalAlignment="Top"
                            Command="{Binding ExportCommand}"
                            Content="导出摘要" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,18,0">
                <Border Padding="20" Background="White" CornerRadius="24">
                    <StackPanel>
                        <TextBlock FontSize="14" Foreground="#5C7299" Text="Unit Overview" />
                        <TextBlock Margin="0,12,0,0" FontSize="28" FontWeight="Bold" Text="{Binding SelectedPackageName}" />
                        <TextBlock Margin="0,8,0,0" FontSize="16" Foreground="#37548A" Text="{Binding SelectedCustomer}" />
                        <Separator Margin="0,14,0,14" />
                        <TextBlock FontWeight="SemiBold" Text="AI Model" />
                        <TextBlock Margin="0,6,0,0" Foreground="#5C7299" Text="{Binding AiModelVersion}" />
                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="AI Decision" />
                        <TextBlock Margin="0,6,0,0" Foreground="#5C7299" Text="{Binding AiDecision}" />
                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Recommendation" />
                        <TextBlock Margin="0,6,0,0" Foreground="#5C7299" TextWrapping="Wrap" Text="{Binding AiRecommendation}" />
                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Engineer Summary" />
                        <TextBlock Margin="0,6,0,0" Foreground="#5C7299" TextWrapping="Wrap" Text="{Binding EngineerSummary}" />
                        <Border Margin="0,18,0,0"
                                Padding="14"
                                Background="#EEF4FF"
                                CornerRadius="16">
                            <StackPanel>
                                <TextBlock Foreground="#4C69A1" Text="Risk Level" />
                                <TextBlock Margin="0,8,0,0" FontSize="20" FontWeight="Bold" Foreground="#143B84" Text="{Binding RiskLevel}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="220" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20" Background="White" CornerRadius="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.ColumnSpan="3" ItemsSource="{Binding ReviewImages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,14,0"
                                            CornerRadius="18"
                                            BorderBrush="#D9E4F7"
                                            BorderThickness="1"
                                            Background="#FAFCFF">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="120" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Background="#214693" CornerRadius="18,18,0,0">
                                                <TextBlock VerticalAlignment="Bottom"
                                                           Margin="16"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           Text="{Binding Title}" />
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="16">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Source}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="#5C7299"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Finding}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Foreground="#143B84"
                                                           FontWeight="Bold"
                                                           Text="{Binding Verdict}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#5C7299"
                                                           Text="{Binding ConfidenceText}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="20" Background="White" CornerRadius="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="0.9*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="Bold" Text="站点履历" />
                            <ScrollViewer Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Route}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12"
                                                    Padding="14"
                                                    Background="#F7FAFF"
                                                    CornerRadius="16"
                                                    BorderBrush="#DBE5F8"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="Bold"
                                                                   Text="{Binding StationName}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="#37548A"
                                                                   Text="{Binding EquipmentCode}" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Foreground="#5C7299"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding Summary}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                        <TextBlock HorizontalAlignment="Right"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding Status}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="#5C7299"
                                                                   Text="{Binding Timestamp}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="工程日志" />
                            <Border Margin="0,14,0,0"
                                    Padding="14"
                                    CornerRadius="16"
                                    Background="#0F1F4A">
                                <ListBox ItemsSource="{Binding ActivityLogs}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#DCE6FF" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" Background="#18316E" CornerRadius="24">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="#9CC4FF" Text="Resume Fit" />
                    <TextBlock Margin="12,0,0,0"
                               Foreground="White"
                               Text="WPF(MVVM) / 物料影像回溯 / AOI 复判 / 工程工具抽象" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="18,0,0,0" Padding="18" Background="White" CornerRadius="24">
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="面试讲法" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#5C7299"
                               TextWrapping="Wrap"
                               Text="这个 demo 不是单纯查列表，而是把序列号、工序、站点设备、影像和 AI 复判组织成一个工程人员真正会使用的分析工作台。" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
